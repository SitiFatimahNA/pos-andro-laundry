<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.POSLaundry" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/accent_gold</item>
        <item name="colorPrimaryVariant">@color/accent_gold</item>
        <item name="colorOnPrimary">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Elegant" parent="TextAppearance.MaterialComponents.Subtitle1">
    </style>

    <style name="TextAppearance.Elegant.DisplayName">
        <item name="android:fontFamily">@font/cormorant_garamond_semibold</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Elegant.Amount">
        <item name="android:fontFamily">@font/cormorant_garamond_medium</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.04</item>
    </style>

    <!-- Style teks: Label kecil uppercase sans -->
    <style name="TextAppearance.Elegant.Label">
        <item name="android:fontFamily">@font/dm_sans_regular</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Style teks: Menu card title -->
    <style name="TextAppearance.Elegant.MenuTitle">
        <item name="android:fontFamily">@font/dm_sans_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Style teks: Menu card subtitle -->
    <style name="TextAppearance.Elegant.MenuSubtitle">
        <item name="android:fontFamily">@font/dm_sans_regular</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
    <!-- Base application theme. -->
    <style name="Base.Theme.Pos" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Pos" parent="Base.Theme.Pos" />
</resources>