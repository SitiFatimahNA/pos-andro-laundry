<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page"
    tools:context=".RiwayatTransaksiActivity">

    <!-- ══════ HEADER ══════ -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_header"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="40dp"
        android:paddingBottom="50dp"
        android:clipToPadding="false">

        <!-- Tombol Kembali kiri -->
        <ImageView
            android:id="@+id/ivKembali"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_alignParentStart="true"
            android:layout_alignTop="@id/tvHeaderTitle"
            android:background="@drawable/bg_circle_notif"
            android:contentDescription="Kembali"
            android:padding="9dp"
            android:src="@drawable/ic_back" />

        <!-- Judul Halaman -->
        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"
            android:text="Riwayat Transaksi"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Placeholder kanan agar judul tetap tengah -->
        <View
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/tvHeaderTitle" />

    </RelativeLayout>

    <!-- ══════ WRAPPER KONTEN (RecyclerView melayang di atas header) ══════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Background putih pengisi area bawah -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_page" />

        <!-- RecyclerView dengan margin negatif agar melayang ke atas -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRiwayat"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="-26dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="0dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false" />

    </FrameLayout>

</LinearLayout>