<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="18dp"
    android:layout_marginEnd="18dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    android:background="@color/bg_card"
    tools:context=".item_pegawai">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Foto Pegawai -->
        <androidx.cardview.widget.CardView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivFotoPegawai"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_camera" />

                <!-- Overlay placeholder -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp" />
                </LinearLayout>

            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Info Pegawai -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Nama -->
            <TextView
                android:id="@+id/tvNamaPegawai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Pegawai"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="3dp" />

            <!-- Jabatan chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_date"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginBottom="5dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_dot_gold"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:id="@+id/tvJabatan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jabatan"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.03" />
            </LinearLayout>

            <!-- No HP -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@drawable/bg_icon_teal"
                    android:gravity="center"
                    android:layout_marginEnd="5dp">

                    <ImageView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:src="@drawable/ic_branch"
                        app:tint="@color/icon_teal" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvNoHp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08xx-xxxx-xxxx"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Chip Status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aktif"
                android:textColor="@color/icon_sage"
                android:textSize="10sp"
                android:textStyle="bold"
                app:chipCornerRadius="12dp"
                app:chipIcon="@drawable/ic_check"
                app:chipIconTint="@color/icon_sage"
                app:chipIconVisible="true"
                app:chipMinHeight="28dp"
                app:chipStrokeWidth="0dp"
                app:iconStartPadding="4dp" />

            <View
                android:layout_width="18dp"
                android:layout_height="1.5dp"
                android:background="@color/accent_gold"
                android:layout_marginTop="6dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>