<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:fillViewport="true"
    tools:context=".mod_pegawai">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════ HEADER ══════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_header"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="40dp"
            android:paddingBottom="50dp"
            android:clipToPadding="false">

            <ImageView
                android:id="@+id/ivKembali"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_alignParentStart="true"
                android:layout_alignTop="@id/tvJudul"
                android:background="@drawable/bg_circle_notif"
                android:contentDescription="Kembali"
                android:padding="9dp"
                android:src="@drawable/ic_back" />

            <TextView
                android:id="@+id/tvJudul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:text="Tambah Pegawai"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <View
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_alignParentEnd="true"
                android:layout_alignTop="@id/tvJudul" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- ══════ FOTO ══════ -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="22dp">

                <ImageView
                    android:id="@+id/ivFoto"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_camera"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_icon_slate"
                    android:padding="24dp" />

                <LinearLayout
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_icon_gold"
                    android:gravity="center">
                    <ImageView
                        android:id="@+id/ivEditFoto"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_camera"
                        android:contentDescription="Edit Foto"
                        app:tint="@color/accent_gold" />
                </LinearLayout>

            </FrameLayout>

            <!-- ══════ DIVIDER LABEL ══════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATA PEGAWAI"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:layout_marginEnd="10dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/border_default" />
            </LinearLayout>

            <!-- ══════ NAMA ══════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_quick_item"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Pegawai"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_gold"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_account"
                            android:contentDescription="Nama"
                            app:tint="@color/accent_gold" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/border_default">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNama"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Masukkan nama pegawai"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="13sp"
                            android:inputType="textPersonName" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <View
                    android:layout_width="18dp"
                    android:layout_height="1.5dp"
                    android:layout_marginTop="10dp"
                    android:background="@color/accent_gold" />
            </LinearLayout>

            <!-- ══════ JABATAN ══════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_quick_item"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jabatan"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_rose"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_employee"
                            android:contentDescription="Jabatan"
                            app:tint="@color/icon_rose" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/border_default">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etJabatan"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Masukkan jabatan"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="13sp"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <View
                    android:layout_width="18dp"
                    android:layout_height="1.5dp"
                    android:layout_marginTop="10dp"
                    android:background="@color/line_rose" />
            </LinearLayout>

            <!-- ══════ NO HP ══════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="22dp"
                android:background="@drawable/bg_quick_item"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nomor HP"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_sage"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_phone"
                            android:contentDescription="Nomor HP"
                            app:tint="@color/icon_sage" />
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="@color/border_default">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNoHp"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Masukkan nomor HP"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="13sp"
                            android:inputType="phone" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <View
                    android:layout_width="18dp"
                    android:layout_height="1.5dp"
                    android:layout_marginTop="10dp"
                    android:background="@color/line_sage" />
            </LinearLayout>

            <!-- ══════ TOMBOL SIMPAN ══════ -->
            <Button
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Simpan Pegawai"
                android:textColor="@color/bg_header"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:backgroundTint="@color/accent_gold"
                app:cornerRadius="26dp"
                app:icon="@drawable/ic_check"
                app:iconTint="@color/bg_header"
                app:iconGravity="textStart" />

        </LinearLayout>
    </LinearLayout>

</ScrollView>