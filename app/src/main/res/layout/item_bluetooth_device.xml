<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="18dp"
    android:layout_marginEnd="18dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    android:background="@color/bg_card"
    tools:context=".ItemBluetoothDevice">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Icon Printer -->
        <LinearLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_icon_slate"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_printer"
                android:contentDescription="Printer"
                app:tint="@color/icon_slate" />
        </LinearLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvNamaDevice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Printer"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMacDevice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="XX:XX:XX:XX:XX:XX"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <!-- Garis aksen bawah -->
            <View
                android:layout_width="18dp"
                android:layout_height="1.5dp"
                android:layout_marginTop="6dp"
                android:background="@color/line_slate" />

        </LinearLayout>

        <!-- Tombol Pilih -->
        <com.google.android.material.chip.Chip
            android:id="@+id/tvPilih"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Pilih"
            android:textSize="11sp"
            android:textColor="@color/icon_slate"
            app:chipCornerRadius="20dp"
            app:chipStrokeWidth="0dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>