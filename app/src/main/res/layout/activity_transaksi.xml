<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:fitsSystemWindows="true"
    tools:context=".TransaksiActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══════ HEADER ══════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="50dp"
            android:paddingBottom="50dp">

            <ImageView
                android:id="@+id/ivKembali"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_notif"
                android:padding="9dp"
                android:src="@drawable/ic_back"
                android:contentDescription="Kembali"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Transaksi Baru"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <ImageView
                android:id="@+id/ivRiwayat"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_notif"
                android:padding="9dp"
                android:src="@drawable/ic_report"
                android:contentDescription="Riwayat"
                app:tint="@color/text_primary" />
        </RelativeLayout>


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_card"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="18dp"
                android:paddingTop="6dp">

                <!-- ══════ DIVIDER LABEL ══════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INFORMASI TRANSAKSI"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.15"
                        android:layout_marginEnd="10dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/border_default" />
                </LinearLayout>

                <!-- ══════ NOMOR TRANSAKSI ══════ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    android:background="@color/bg_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/bg_card"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No. Transaksi"
                            android:textColor="@color/text_hint"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_icon_gold"
                                android:gravity="center"
                                android:layout_marginEnd="10dp">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_queue"
                                    android:contentDescription="Nomor Transaksi"
                                    app:tint="@color/accent_gold" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvNomorTransaksi"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="TRX-..."
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="18dp"
                            android:layout_height="1.5dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/accent_gold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ══════ PELANGGAN ══════ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    android:background="@color/bg_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/bg_card"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pelanggan"
                            android:textColor="@color/text_hint"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_icon_slate"
                                android:gravity="center"
                                android:layout_marginEnd="10dp">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_customer"
                                    android:contentDescription="Pelanggan"
                                    app:tint="@color/icon_slate" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvNamaPelanggan"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Belum dipilih"
                                android:textColor="@color/text_hint"
                                android:textSize="13sp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/btnPilihPelanggan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pilih"
                                android:textSize="11sp"
                                android:textColor="@color/icon_slate"
                                app:chipCornerRadius="20dp"
                                app:chipStrokeWidth="0dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="18dp"
                            android:layout_height="1.5dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/line_slate" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ══════ CABANG ══════ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    android:background="@color/bg_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/bg_card"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cabang"
                            android:textColor="@color/text_hint"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_icon_teal"
                                android:gravity="center"
                                android:layout_marginEnd="10dp">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_branch"
                                    android:contentDescription="Cabang"
                                    app:tint="@color/icon_teal" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvNamaCabang"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Belum dipilih"
                                android:textColor="@color/text_hint"
                                android:textSize="13sp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/btnPilihCabang"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pilih"
                                android:textSize="11sp"
                                android:textColor="@color/icon_teal"
                                app:chipCornerRadius="20dp"
                                app:chipStrokeWidth="0dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="18dp"
                            android:layout_height="1.5dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/line_teal" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ══════ DIVIDER PRODUK ══════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRODUK / LAYANAN"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.15"
                        android:layout_marginEnd="10dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/border_default" />
                </LinearLayout>

                <!-- ══════ PRODUK / LAYANAN ══════ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    android:background="@color/bg_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/bg_card"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <LinearLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_icon_sage"
                                android:gravity="center"
                                android:layout_marginEnd="10dp">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_service"
                                    android:contentDescription="Produk"
                                    app:tint="@color/icon_sage" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Item dipilih"
                                android:textColor="@color/text_hint"
                                android:textSize="10sp"
                                android:letterSpacing="0.05" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/btnTambahProduk"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+ Tambah"
                                android:textSize="11sp"
                                android:textColor="@color/icon_sage"
                                app:chipCornerRadius="20dp"
                                app:chipStrokeWidth="0dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/llItemProduk"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <TextView
                            android:id="@+id/tvKosong"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="12dp"
                            android:text="Belum ada produk dipilih"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="18dp"
                            android:layout_height="1.5dp"
                            android:layout_marginTop="6dp"
                            android:background="@color/line_sage" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ══════ DIVIDER PEMBAYARAN ══════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PEMBAYARAN"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:letterSpacing="0.15"
                        android:layout_marginEnd="10dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/border_default" />
                </LinearLayout>

                <!-- ══════ METODE PEMBAYARAN ══════ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    android:background="@color/bg_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/bg_card"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Metode Pembayaran"
                            android:textColor="@color/text_hint"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="10dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnTunai"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:text="Tunai"
                                android:textSize="10sp"
                                android:textColor="@color/accent_gold"
                                android:backgroundTint="@color/bg_card"
                                app:cornerRadius="14dp"
                                app:icon="@drawable/ic_money"
                                app:iconTint="@color/accent_gold"
                                app:iconGravity="textStart"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                app:strokeColor="@color/border_default"
                                app:strokeWidth="1dp" />

                            <Button
                                android:id="@+id/btnTransfer"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:layout_marginEnd="4dp"
                                android:text="Transfer"
                                android:textSize="10sp"
                                android:textColor="@color/icon_slate"
                                android:backgroundTint="@color/bg_card"
                                app:cornerRadius="14dp"
                                app:icon="@drawable/ic_transfer"
                                app:iconTint="@color/icon_slate"
                                app:iconGravity="textStart"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                app:strokeColor="@color/border_default"
                                app:strokeWidth="1dp" />

                            <Button
                                android:id="@+id/btnQris"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:text="QRIS"
                                android:textSize="10sp"
                                android:textColor="@color/icon_mist"
                                android:backgroundTint="@color/bg_card"
                                app:cornerRadius="14dp"
                                app:icon="@drawable/ic_qris"
                                app:iconTint="@color/icon_mist"
                                app:iconGravity="textStart"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                app:strokeColor="@color/border_default"
                                app:strokeWidth="1dp" />

                        </LinearLayout>

                        <View
                            android:layout_width="18dp"
                            android:layout_height="1.5dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/accent_gold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ══════ CATATAN ══════ -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    android:background="@color/bg_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/bg_card"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Catatan"
                            android:textColor="@color/text_hint"
                            android:textSize="10sp"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top">

                            <LinearLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_icon_rose"
                                android:gravity="center"
                                android:layout_marginEnd="10dp"
                                android:layout_marginTop="6dp">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_note"
                                    android:contentDescription="Catatan"
                                    app:tint="@color/icon_rose" />
                            </LinearLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxStrokeColor="@color/border_default">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etCatatan"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:minHeight="80dp"
                                    android:hint="Catatan (opsional)"
                                    android:textColor="@color/text_primary"
                                    android:textColorHint="@color/text_hint"
                                    android:textSize="13sp"
                                    android:inputType="textMultiLine"
                                    android:gravity="top"
                                    android:lines="3" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="18dp"
                            android:layout_height="1.5dp"
                            android:layout_marginTop="10dp"
                            android:background="@color/line_rose" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>

        <!-- ══════ BOTTOM TOTAL & BAYAR ══════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="0dp"
            app:cardElevation="8dp"
            android:background="@color/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_card"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL PEMBAYARAN"
                            android:textColor="@color/text_hint"
                            android:textSize="10sp"
                            android:letterSpacing="0.12"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/tvTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textColor="@color/text_primary"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="36dp"
                        android:background="@color/border_default"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_gold"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_queue"
                            android:contentDescription="Total"
                            app:tint="@color/accent_gold" />
                    </LinearLayout>

                </LinearLayout>

                <Button
                    android:id="@+id/btnBayar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="@color/accent_gold"
                    android:text="Proses Pembayaran"
                    android:textColor="@color/bg_header"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    app:cornerRadius="26dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>