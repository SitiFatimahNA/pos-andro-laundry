<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="18dp"
    android:layout_marginEnd="18dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    android:background="@color/bg_card"
    tools:context=".item_riwayat_transaksi">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Ikon Transaksi -->
        <LinearLayout
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_icon_gold"
            android:gravity="center"
            android:layout_marginEnd="14dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_queue"
                app:tint="@color/accent_gold" />
        </LinearLayout>

        <!-- Konten Tengah -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Nomor Transaksi -->
            <TextView
                android:id="@+id/tvNomorRiwayat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRX-..."
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp" />

            <!-- Nama Pelanggan -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:background="@drawable/bg_icon_slate"
                    android:gravity="center"
                    android:layout_marginEnd="5dp">

                    <ImageView
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:src="@drawable/ic_customer"
                        app:tint="@color/icon_slate" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPelangganRiwayat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pelanggan"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Tanggal + Metode -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Chip Tanggal -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_date"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginEnd="6dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:background="@drawable/bg_dot_gold"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:id="@+id/tvTanggalRiwayat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2026-01-01"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:letterSpacing="0.03" />
                </LinearLayout>

                <!-- Chip Metode -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_icon_sage"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp">

                    <TextView
                        android:id="@+id/tvMetodeRiwayat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tunai"
                        android:textColor="@color/icon_sage"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.03" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- Total Kanan -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL"
                android:textColor="@color/text_hint"
                android:textSize="9sp"
                android:letterSpacing="0.10"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvTotalRiwayat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>