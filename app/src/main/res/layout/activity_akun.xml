<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:fillViewport="true"
    tools:context=".AkunActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <!-- ══════ HEADER ══════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_header"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="40dp"
            android:paddingBottom="50dp"
            android:clipToPadding="false">

            <!-- Tombol Kembali kiri -->
            <ImageView
                android:id="@+id/ivKembali"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_alignParentStart="true"
                android:layout_alignTop="@id/tvPageTitle"
                android:background="@drawable/bg_circle_notif"
                android:contentDescription="Kembali"
                android:padding="10dp"
                android:src="@drawable/ic_back" />

            <!-- Judul halaman tengah -->
            <TextView
                android:id="@+id/tvPageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:text="Akun"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Spacer kanan agar judul tetap center -->
            <View
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_alignParentEnd="true"
                android:layout_alignTop="@id/tvPageTitle" />

        </RelativeLayout>

        <!-- ══════ CARD FOTO & INFO PROFIL (floating) ══════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="-26dp"
            android:layout_marginBottom="14dp"
            android:background="@color/bg_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:background="@color/bg_card"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_marginBottom="14dp">

                    <ImageView
                        android:id="@+id/ivFotoProfil"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="@drawable/ic_laundry"
                        android:scaleType="centerCrop" />

                    <LinearLayout
                        android:id="@+id/ivEditFoto"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_icon_gold"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/accent_gold" />
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tvNama"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Pengguna"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Chip Role -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/bg_chip_date"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="11dp"
                    android:paddingEnd="11dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp">

                    <View
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_dot_gold" />

                    <TextView
                        android:id="@+id/tvRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Admin"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="email@pos.com"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════ DIVIDER PENGATURAN ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="6dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENGATURAN"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginEnd="10dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/border_default" />
        </LinearLayout>

        <!-- ══════ CARD MENU ══════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="14dp"
            android:background="@color/bg_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/bg_card"
                android:padding="8dp">

                <!-- Edit Profil -->
                <LinearLayout
                    android:id="@+id/menuEditProfil"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp">

                    <LinearLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_icon_gold"
                        android:gravity="center"
                        android:layout_marginEnd="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/accent_gold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit Profil"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ubah nama &amp; foto"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_back"
                        app:tint="@color/text_hint" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="66dp"
                    android:background="@color/border_default" />

                <!-- Ganti Password -->
                <LinearLayout
                    android:id="@+id/menuGantiPassword"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp">

                    <LinearLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_icon_slate"
                        android:gravity="center"
                        android:layout_marginEnd="14dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/icon_slate" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ganti Password"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Perbarui kata sandi"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_back"
                        app:tint="@color/text_hint" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════ DIVIDER LAINNYA ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LAINNYA"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginEnd="10dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/border_default" />
        </LinearLayout>

        <!-- ══════ BANNER LOGOUT ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_banner"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="15dp">

            <LinearLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_circle_banner_icon"
                android:gravity="center"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_favorite"
                    android:contentDescription="Info"
                    app:tint="@color/accent_gold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terima kasih sudah bekerja keras"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sampai jumpa lagi!"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══════ TOMBOL LOGOUT ══════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#FFF0F0"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Keluar"
                    android:textColor="#E53935"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_back"
                    app:tint="#E53935" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>