<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="18dp"
    android:layout_marginEnd="18dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    android:background="@color/bg_card"
    tools:context=".Item_cabang">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Icon -->
        <LinearLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_icon_teal"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_branch"
                android:contentDescription="Cabang"
                app:tint="@color/icon_teal" />
        </LinearLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvNamaCabang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Cabang"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAlamat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alamat cabang"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvNoTelp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08xx-xxxx-xxxx"
                android:textColor="#6B3FA0"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <!-- Garis bawah aksen, sama seperti card menu utama -->
            <View
                android:layout_width="18dp"
                android:layout_height="1.5dp"
                android:layout_marginTop="6dp"
                android:background="@color/line_teal" />

        </LinearLayout>

        <!-- Chip Status -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aktif"
            android:textColor="@color/icon_sage"
            android:textSize="10sp"
            android:textStyle="bold"
            app:chipCornerRadius="12dp"
            app:chipIcon="@drawable/ic_check"
            app:chipIconTint="@color/icon_sage"
            app:chipIconVisible="true"
            app:chipMinHeight="28dp"
            app:chipStrokeWidth="0dp"
            app:iconStartPadding="4dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>