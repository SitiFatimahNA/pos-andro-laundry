<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="18dp"
    android:layout_marginEnd="18dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    android:background="@color/bg_card"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    tools:context=".item_data_kategori">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Ikon Kategori -->
        <LinearLayout
            android:id="@+id/iconCard"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_icon_gold"
            android:gravity="center"
            android:layout_marginEnd="14dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tag"
                app:tint="@color/accent_gold" />
        </LinearLayout>

        <!-- Nama Kategori -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvKategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="18dp"
                android:layout_height="1.5dp"
                android:background="@color/accent_gold" />
        </LinearLayout>

        <!-- Chip Status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aktif"
                android:textColor="@color/icon_sage"
                android:textSize="10sp"
                android:textStyle="bold"
                app:chipCornerRadius="12dp"
                app:chipIcon="@drawable/ic_check"
                app:chipIconTint="@color/icon_sage"
                app:chipIconVisible="true"
                app:chipMinHeight="28dp"
                app:chipStrokeWidth="0dp"
                app:iconStartPadding="4dp" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>