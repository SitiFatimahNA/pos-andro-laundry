<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_header"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="40dp"
            android:paddingBottom="50dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/greetingGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreetingSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SELAMAT SIANG"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGreetingName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zahra"
                    android:textColor="@color/text_primary"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chipDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_below="@id/greetingGroup"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_chip_date"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="11dp"
                android:paddingEnd="11dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp">

                <View
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:background="@drawable/bg_dot_gold"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08 Januari 2026"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.05" />
            </LinearLayout>

        </RelativeLayout>

        <!-- ══════ CARD STATISTIK PASIEN ══════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="-26dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESTIMASI HARI INI"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="5dp" />

                <TextView
                    android:id="@+id/tvEstimation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 0"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="18dp" />

                <!-- Quick actions: Antrian | Pasien | Laporan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Antrian -->
                    <LinearLayout
                        android:id="@+id/menuTransaksi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_quick_item"
                        android:padding="11dp"
                        android:layout_marginEnd="4dp">

                        <LinearLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_icon_gold"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_queue"
                                android:contentDescription="Antrian"
                                app:tint="@color/accent_gold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:text="Transaksi"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Pasien -->
                    <LinearLayout
                        android:id="@+id/menuPelanggan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_quick_item"
                        android:padding="11dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp">

                        <LinearLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_icon_slate"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_customer"
                                android:contentDescription="Pelanggan"
                                app:tint="@color/icon_slate" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:text="Pelanggan"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Laporan -->
                    <LinearLayout
                        android:id="@+id/menuLaporan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_quick_item"
                        android:padding="11dp"
                        android:layout_marginStart="4dp">

                        <LinearLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_icon_sage"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_report"
                                android:contentDescription="Laporan"
                                app:tint="@color/icon_sage" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:text="Laporan"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════ BANNER MOTIVASI ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_banner"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="15dp">

            <LinearLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_circle_banner_icon"
                android:gravity="center"
                android:layout_marginEnd="12dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_favorite"
                    android:contentDescription="Motivasi"
                    app:tint="@color/accent_gold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Siap melayani dengan sepenuh hati"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jangan kecewakan pelanggan hari ini"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══════ DIVIDER MENU UTAMA ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="22dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MENU UTAMA"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:layout_marginEnd="10dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/border_default" />
        </LinearLayout>

        <!-- ══════ BARIS 1: Akun + Layanan ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:layout_marginBottom="8dp">

            <!-- AKUN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAkun"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_icon_gold"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_account"
                            android:contentDescription="Akun"
                            app:tint="@color/accent_gold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Akun"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kelola profil"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp" />

                    <View
                        android:layout_width="18dp"
                        android:layout_height="1.5dp"
                        android:background="@color/accent_gold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- LAYANAN MEDIS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLayanan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_icon_sage"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_service"
                            android:contentDescription="Layanan Medis"
                            app:tint="@color/icon_sage" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Layanan"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daftar Layanan"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp" />

                    <View
                        android:layout_width="18dp"
                        android:layout_height="1.5dp"
                        android:background="@color/line_sage" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ══════ BARIS 2: Obat + Dokter ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:layout_marginBottom="8dp">

            <!-- OBAT -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTambahan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_icon_mist"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_add"
                            android:contentDescription="Obat"
                            app:tint="@color/icon_mist" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tambahan"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Item Tambahan"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="18dp"
                        android:layout_height="1.5dp"
                        android:background="@color/line_mist" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- DOKTER -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPegawai"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_icon_rose"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_employee"
                            android:contentDescription="Dokter"
                            app:tint="@color/icon_rose" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pegawai"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manajemen staf"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp" />

                    <View
                        android:layout_width="18dp"
                        android:layout_height="1.5dp"
                        android:background="@color/line_rose" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ══════ BARIS 3: Cabang + Printer ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <!-- CABANG -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCabang"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_icon_teal"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_branch"
                            android:contentDescription="Cabang"
                            app:tint="@color/icon_teal" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cabang"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lokasi usaha"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp" />

                    <View
                        android:layout_width="18dp"
                        android:layout_height="1.5dp"
                        android:background="@color/line_teal" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- PRINTER -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPrinter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_icon_slate"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_printer"
                            android:contentDescription="Printer"
                            app:tint="@color/icon_slate" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Printer"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pengaturan cetak"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp" />

                    <View
                        android:layout_width="18dp"
                        android:layout_height="1.5dp"
                        android:background="@color/line_slate" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>